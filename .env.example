# Core mode
MODE=paper
# Mode options: paper, dry-run

# Exchanges (CSV)
EXCHANGES=binance,bybit,okx,kucoin
SYMBOLS=BTC/USDT,ETH/USDT

# Polling and thresholds
POLL_INTERVAL_SEC=2.0
MIN_NET_SPREAD_PCT=0.15
SLIPPAGE_PCT=0.05
MAX_DATA_AGE_MS=3500

# Risk controls
MAX_DAILY_DRAWDOWN_PCT=1.0
CAPITAL_PER_EXCHANGE_USDT=1000
CAPITAL_PER_TRADE_USDT=150
MAX_POSITION_PER_SYMBOL=0.02
MIN_NOTIONAL_USDT=20
TRADE_COOLDOWN_SEC=8
MAX_CONSECUTIVE_FAILURES=8
STATUS_LOG_INTERVAL_SEC=30
MAX_OPPORTUNITIES_PER_CYCLE=3
MAX_OPPORTUNITY_AGE_MS=1200

# Depth-aware signal quality
ENABLE_ORDERBOOK_DEPTH=true
REQUIRE_DEPTH_LIQUIDITY=true
ORDERBOOK_DEPTH_LEVELS=5
ORDERBOOK_IMPACT_NOTIONAL_USDT=150

# Inventory rebalance (paper simulation)
REBALANCE_THRESHOLD_PCT=35
REBALANCE_INTERVAL_SEC=120
REBALANCE_FEE_PCT=0.02

# Local dashboard
DASHBOARD_ENABLED=true
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8080

# Optional Telegram alerting
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional API credentials
BINANCE_API_KEY=
BINANCE_API_SECRET=

BYBIT_API_KEY=
BYBIT_API_SECRET=

OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSWORD=

KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_PASSWORD=
