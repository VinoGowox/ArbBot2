# Core mode
MODE=dry-run
# Mode options: paper, dry-run
EXECUTION_STYLE=maker-taker
# Execution style options: taker-taker, maker-taker
MAKER_SIDE_PREFERENCE=buy
# Maker side options: buy, sell

# Exchanges (CSV)
EXCHANGES=binance,bybit,okx,kucoin
SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT,XRP/USDT,ADA/USDT

# Polling and thresholds
POLL_INTERVAL_SEC=1.0
MIN_NET_SPREAD_PCT=-0.20
SLIPPAGE_PCT=0.02
USE_DYNAMIC_SLIPPAGE=true
AUTO_THRESHOLD_ENABLED=false
AUTO_THRESHOLD_COST_BUFFER_RATIO=0.25
AUTO_THRESHOLD_MIN_FLOOR_PCT=0.03
MAX_DATA_AGE_MS=3500

# Fill/queue model (maker-taker)
FILL_PROBABILITY_EDGE_REF_PCT=0.12
QUEUE_RISK_SENSITIVITY=1.0
MAKER_ORDER_TIMEOUT_MS=2200
MAKER_MAX_REQUOTES=3
MAKER_REQUOTE_STEP_BPS=0.8
MAKER_MIN_FILL_PROBABILITY=0.20
MAKER_REQUOTE_FILL_BOOST=0.20
# Temporary smoke-test switch: allow route execution in dry-run even when modeled edge is <= 0.
ALLOW_NEGATIVE_EXPECTED_PROFIT_DRYRUN=true

# Hybrid market data (Binance + Bybit WS, REST fallback)
ENABLE_WEBSOCKET_MARKET_DATA=true
WEBSOCKET_STALE_MS=6000

# Optional taker fee overrides (decimal form)
FEE_TAKER_BINANCE=0.0008
FEE_TAKER_BYBIT=0.0008
FEE_TAKER_OKX=0.0008
FEE_TAKER_KUCOIN=0.0008

# Optional maker fee overrides (decimal form)
FEE_MAKER_BINANCE=0.0002
FEE_MAKER_BYBIT=0.0002
FEE_MAKER_OKX=0.0002
FEE_MAKER_KUCOIN=0.0002

# Risk controls
MAX_DAILY_DRAWDOWN_PCT=1.0
CAPITAL_PER_EXCHANGE_USDT=1000
CAPITAL_PER_TRADE_USDT=40
MAX_POSITION_PER_SYMBOL=5
MIN_NOTIONAL_USDT=5
TRADE_COOLDOWN_SEC=3
MAX_CONSECUTIVE_FAILURES=8
STATUS_LOG_INTERVAL_SEC=30
MAX_OPPORTUNITIES_PER_CYCLE=1
MAX_OPPORTUNITY_AGE_MS=1200

# Depth-aware signal quality
ENABLE_ORDERBOOK_DEPTH=true
REQUIRE_DEPTH_LIQUIDITY=false
ORDERBOOK_DEPTH_LEVELS=5
ORDERBOOK_IMPACT_NOTIONAL_USDT=40

# Inventory rebalance (paper simulation)
REBALANCE_THRESHOLD_PCT=35
REBALANCE_INTERVAL_SEC=120
REBALANCE_FEE_PCT=0.02

# Local dashboard
DASHBOARD_ENABLED=true
DASHBOARD_HOST=127.0.0.1
# Use unprivileged port (>1024) unless you intentionally grant CAP_NET_BIND_SERVICE.
DASHBOARD_PORT=8080

# Optional Telegram alerting
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional API credentials
BINANCE_API_KEY=
BINANCE_API_SECRET=

BYBIT_API_KEY=
BYBIT_API_SECRET=

OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSWORD=

KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_PASSWORD=
